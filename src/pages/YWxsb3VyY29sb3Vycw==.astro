---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import VaultPlayer from "../components/VaultPlayer.astro";
import "../styles/global.css";
---

<Layout
  title="SECURE VAULT — NRVA"
  description="CLASSIFIED AUDIO // SECURE VAULT ACCESSED"
>
  <Navbar isCorePage={true} />

  <main
    class="relative w-full h-[100dvh] overflow-hidden flex flex-col justify-center items-center px-4 sm:px-6 pt-16"
  >
    <!-- MATRIX BACKGROUND -->
    <div
      class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none opacity-10 sm:opacity-20 mask-image-fade"
    >
      <canvas id="matrix-canvas-vault" class="w-full h-full block"></canvas>
    </div>

    <div class="w-full">
      <div class="text-center mb-8 reveal-on-scroll mt-4">
        <span class="font-mono text-[#0dbc79] text-xs tracking-widest uppercase"
          >CLASSIFIED AUDIO // SECURE VAULT ACCESSED</span
        >
      </div>

      <div class="reveal-on-scroll" style="transition-delay: 100ms;">
        <VaultPlayer
          trackTitle="All Our Colours — Preview"
          trackArtist="NRVA — Unreleased Scripture"
          audioSrc="/SSM_002.wav"
          nextUrl="/YXN3ZWV0bWlyYWdl"
        />
      </div>
    </div>
  </main>
  <Footer isCompact={true} />

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import Lenis from "lenis";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("astro:page-load", () => {
      /* ── MATRIX RAIN EFFECT ── */
      const canvas = document.getElementById(
        "matrix-canvas-vault",
      ) as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;

      const chars =
        "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789$+-*/=%\"'#&_(),.;:?!\\|{}<>[]^~";
      const charArray = chars.split("");
      const fontSize = 14;
      const columns = canvas.width / fontSize;
      const drops = Array.from({ length: columns }).fill(1) as number[];

      let matrixInterval: NodeJS.Timeout;

      function drawMatrix() {
        ctx.fillStyle = "rgba(0, 0, 0, 0.05)";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = "#0dbc79";
        ctx.font = `${fontSize}px "JetBrains Mono", monospace`;

        for (let i = 0; i < drops.length; i++) {
          const text = charArray[Math.floor(Math.random() * charArray.length)];
          ctx.fillText(text, i * fontSize, drops[i] * fontSize);

          if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) {
            drops[i] = 0;
          }
          drops[i]++;
        }
      }

      matrixInterval = setInterval(drawMatrix, 50);

      window.addEventListener("resize", () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      });

      // === LENIS SMOOTH SCROLL ===
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: "vertical",
        gestureOrientation: "vertical",
        smoothWheel: true,
      });

      lenis.on("scroll", ScrollTrigger.update);
      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);

      // === GSAP SCROLL REVEAL ===
      const revealElements = gsap.utils.toArray(".reveal-on-scroll");
      revealElements.forEach((el) => {
        ScrollTrigger.create({
          trigger: el as Element,
          start: "top 85%",
          onEnter: () => (el as Element).classList.add("is-visible"),
          once: true,
        });
      });
    });
  </script>
</Layout>
