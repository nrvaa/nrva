  <style>
    /* Secret Terminal Styles */
    #secretTerminal {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 99999;
      background: rgba(0, 0, 0, 0.85);
      backdrop-filter: blur(8px);
      font-family: "JetBrains Mono", monospace;
    }
    .terminal-content {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 90%;
      max-width: 800px;
      height: 70vh;
      background: #050505;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 24px;
      overflow-y: auto;
      color: #0dbc79;
      box-shadow:
        0 0 30px rgba(13, 188, 121, 0.15),
        inset 0 0 10px rgba(13, 188, 121, 0.1);
    }
    /* CRT Scanline effect */
    .terminal-content::before {
      content: " ";
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      right: 0;
      background:
        linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%),
        linear-gradient(
          90deg,
          rgba(255, 0, 0, 0.06),
          rgba(0, 255, 0, 0.02),
          rgba(0, 0, 255, 0.06)
        );
      z-index: 2;
      background-size:
        100% 2px,
        3px 100%;
      pointer-events: none;
      opacity: 0.3;
    }
    #terminalHistory {
      margin-bottom: 12px;
      position: relative;
      z-index: 3;
    }
    .term-line {
      margin-bottom: 8px;
      line-height: 1.5;
      font-size: 14px;
      text-shadow: 0 0 5px rgba(13, 188, 121, 0.5);
    }
    .term-muted {
      color: #0dbc79;
      opacity: 0.7;
    }
    .term-highlight {
      color: #fff;
      font-weight: bold;
      text-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
    }
    .terminal-input-line {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 14px;
      position: relative;
      z-index: 3;
    }
    #terminalInput {
      background: transparent;
      border: none;
      outline: none;
      color: #0dbc79;
      flex: 1;
      font-family: inherit;
      font-size: inherit;
      text-shadow: 0 0 5px rgba(13, 188, 121, 0.5);
      caret-color: #0dbc79;
    }
    .close-hint {
      position: absolute;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      color: rgba(255, 255, 255, 0.4);
      font-family: "JetBrains Mono", monospace;
      font-size: 12px;
      letter-spacing: 2px;
      pointer-events: none;
    }
  </style>

  <script>
    import { onScroll, animate, svg, utils } from "animejs";
    import Lenis from "lenis";
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    // Register GSAP plugins
    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("astro:page-load", () => {
      // === LENIS SMOOTH SCROLL ===
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: "vertical",
        gestureOrientation: "vertical",
        smoothWheel: true,
      });

      // Synchronize Lenis with GSAP ScrollTrigger
      lenis.on("scroll", ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);

      // em ini secret terminal logic

      /* ── SECRET TERMINAL SYSTEM ── */
      const secretTrigger = document.getElementById("secretTrigger");
      const secretTerminal = document.getElementById("secretTerminal");
      const terminalHistory = document.getElementById("terminalHistory");
      const terminalInput = document.getElementById("terminalInput");

      const mobileCloseTerminal = document.getElementById(
        "mobileCloseTerminal",
      );

      function openTerminal() {
        if (secretTerminal) secretTerminal.style.display = "block";
        document.body.style.overflow = "hidden";
        setTimeout(() => terminalInput?.focus(), 100);
      }
      function closeTerminal() {
        if (secretTerminal) secretTerminal.style.display = "none";
        document.body.style.overflow = "";
      }

      if (secretTrigger) {
        secretTrigger.addEventListener("click", openTerminal);
      }
      if (mobileCloseTerminal) {
        mobileCloseTerminal.addEventListener("click", closeTerminal);
      }

      if (secretTerminal) {
        secretTerminal.addEventListener("click", (e) => {
          if (e.target === secretTerminal) closeTerminal();
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && secretTerminal.style.display === "block")
            closeTerminal();
        });

        function printLine(text, isCmd = false) {
          const line = document.createElement("div");
          line.className = "term-line";
          line.innerHTML = isCmd
            ? `<span class="term-muted">nrva@sundering:~$</span> ${text}`
            : text;
          terminalHistory.appendChild(line);
          terminalHistory.scrollTop = terminalHistory.scrollHeight;
        }

        let commandHistory = [];
        let historyIndex = -1;

        if (terminalInput) {
          terminalInput.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
              const cmd = this.value.trim();
              this.value = "";
              if (cmd) {
                commandHistory.push(cmd);
                historyIndex = commandHistory.length;
                printLine(cmd, true);
                processCommand(cmd);
              }
            } else if (e.key === "ArrowUp") {
              e.preventDefault(); // Prevent cursor moving to start of input
              if (historyIndex > 0) {
                historyIndex--;
                this.value = commandHistory[historyIndex];
              }
            } else if (e.key === "ArrowDown") {
              e.preventDefault();
              if (historyIndex < commandHistory.length - 1) {
                historyIndex++;
                this.value = commandHistory[historyIndex];
              } else {
                historyIndex = commandHistory.length;
                this.value = "";
              }
            }
          });
        }

        function processCommand(cmd) {
          const args = cmd.toLowerCase().split(" ");
          switch (args[0]) {
            case "help":
              printLine("AVAILABLE PROTOCOLS:");
              printLine(
                "- <span class='term-highlight'>DECRYPT [file_id]</span> : Decode fractured memory.",
              );
              printLine(
                "- <span class='term-highlight'>CLEAR</span>             : Wipe terminal memory.",
              );
              printLine(
                "- <span class='term-highlight'>EXIT</span>              : Close session.",
              );
              break;
            case "decrypt":
              if (args[1] === "frag_001") {
                printLine("> DECRYPTING FRAG_001...");
                terminalInput.disabled = true;
                setTimeout(() => {
                  printLine(
                    "<span class='term-highlight'>[ SUCCESS ]</span> DATA RECOVERED.",
                  );
                  printLine(
                    "<i>we've no idea what we've got until we lose it all... Until I Lose You.</i>",
                  );
                  terminalInput.disabled = false;
                  terminalInput.focus();
                }, 1200);
              } else if (args[1] === "frag_002") {
                printLine("> DECRYPTING FRAG_002...");
                terminalInput.disabled = true;
                setTimeout(() => {
                  printLine(
                    "<span class='term-highlight'>[ SUCCESS ]</span> DATA RECOVERED.",
                  );
                  printLine(
                    "<i>and what's left behind is nothing more than... a Sweet Synthetic Memory.</i>",
                  );
                  terminalInput.disabled = false;
                  terminalInput.focus();
                }, 1200);
              } else if (args[1] === "ssm_002") {
                printLine("> VERIFYING OVERRIDE CODE...");
                terminalInput.disabled = true;
                setTimeout(() => {
                  printLine(
                    "<span class='term-highlight'>[ SUCCESS ]</span> CLEARANCE ACCEPTED.",
                  );
                  setTimeout(
                    () => (window.location.href = "/YWxsb3VyY29sb3Vycw=="),
                    1000,
                  );
                }, 1200);
              } else if (args[1] === "ssm_005") {
                printLine("> VERIFYING OVERRIDE CODE...");
                terminalInput.disabled = true;
                setTimeout(() => {
                  printLine(
                    "<span class='term-highlight'>[ SUCCESS ]</span> CLEARANCE ACCEPTED.",
                  );
                  setTimeout(
                    () => (window.location.href = "/YXN3ZWV0bWlyYWdl"),
                    1000,
                  );
                }, 1200);
              } else if (args[1] === "uily_001") {
                printLine("> VERIFYING OVERRIDE CODE...");
                terminalInput.disabled = true;
                setTimeout(() => {
                  printLine(
                    "<span class='term-highlight'>[ SUCCESS ]</span> CLEARANCE ACCEPTED.",
                  );
                  setTimeout(
                    () => (window.location.href = "/YXVpbHlfb25seQ=="),
                    1000,
                  );
                }, 1200);
              } else if (args[1]) {
                printLine(`> ERROR: ${args[1].toUpperCase()} NOT FOUND.`);
              } else {
                printLine("> ERROR: Missing file ID. Usage: DECRYPT [file_id]");
              }
              break;
            case "clear":
              terminalHistory.innerHTML = "";
              break;
            case "exit":
              closeTerminal();
              break;
            default:
              printLine(
                `> Command not recognized: ${args[0]}. Type HELP to view protocols.`,
              );
          }
        }

        printLine("Secure Terminal v1.0.0");
        printLine("Type <span class='term-highlight'>HELP</span> to begin.");
        printLine("");
      }

      // === SMOOTH SCROLL FOR ANCHOR LINKS ===
      document
        .querySelectorAll('a[href^="/#"], a[href^="#"]')
        .forEach((anchor) => {
          anchor.addEventListener("click", function (e) {
            const href = this.getAttribute("href");
            const targetId = href.startsWith("/#") ? href.substring(1) : href;

            if (targetId && targetId !== "#") {
              const targetElement = document.querySelector(targetId);
              if (targetElement) {
                e.preventDefault();
                lenis.scrollTo(targetElement, {
                  offset: -100, // adjust offset for navbar height
                });
              }
            }
          });
        });

      // === GSAP SCROLL REVEAL (Replaces checkReveal) ===
      const revealElements = gsap.utils.toArray(".reveal-on-scroll");
      revealElements.forEach((el) => {
        ScrollTrigger.create({
          trigger: el,
          start: "top 85%", // Trigger when element is 85% from top of viewport
          onEnter: () => el.classList.add("is-visible"),
          once: true,
        });
      });

      // === GSAP STAGGER REVEAL (For Grids like Discography & Presence) ===
      // Target grids that contain cards
      const staggerContainers = gsap.utils.toArray(
        "#discography .grid, .stagger-children",
      );

      staggerContainers.forEach((container) => {
        const children = gsap.utils.toArray(container.children);

        // Hide elements initially
        gsap.set(children, { opacity: 0, y: 40 });

        ScrollTrigger.create({
          trigger: container,
          start: "top 85%",
          once: true,
          onEnter: () => {
            gsap.to(children, {
              opacity: 1,
              y: 0,
              duration: 0.8,
              stagger: 0.1, // Stagger effect
              ease: "power3.out",
              clearProps: "all", // Remove inline styles after animation so hover works
            });
          },
        });
      });

      // === GSAP PARALLAX (Replaces manual scroll event) ===
      const parallaxLayers = gsap.utils.toArray(".parallax-layer");
      parallaxLayers.forEach((layer, i) => {
        const speed = (i + 1) * 0.15; // same speed logic as before
        gsap.to(layer, {
          y: () => -ScrollTrigger.maxScroll(window) * speed,
          ease: "none",
          scrollTrigger: {
            trigger: document.body,
            start: "top top",
            end: "bottom bottom",
            scrub: true,
          },
        });
      });

      // === toggle navbar ===
      const toggleButtons = document.querySelectorAll("[data-collapse]");
      toggleButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const targetId = button.getAttribute("data-collapse");
          if (!targetId) return;
          const targetElement = document.querySelector(targetId);
          if (targetElement) {
            targetElement.classList.toggle("hidden");
            button.classList.toggle("collapse-open");
          }
        });
      });

      // === animejs logo assembly ===
      const logoPaths = document.querySelectorAll("svg.w-128 path");
      if (logoPaths.length > 0) {
        animate(logoPaths, {
          translateX: [() => utils.random(-150, 150), 0],
          translateY: [() => utils.random(-100, 100), 0],
          scale: [() => utils.random(50, 150) / 100, 1],
          rotate: [() => utils.random(-45, 45), 0],
          opacity: [0, 1],
          easing: "easeOutElastic(1, .6)",
          duration: () => utils.random(2000, 3500),
          delay: () => utils.random(0, 500),
        });
      }
    });
  </script>
