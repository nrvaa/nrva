    </section>

    <!-- 3. SECTION: Latest Release -->
    <section id="latest" class="space-y-12 reveal-on-scroll">
      <div class="flex items-center gap-4 pt-8">
        <span class="h-[2px] flex-1 bg-base-content/20 rounded-full"></span>
        <span
          class="font-mono text-sm tracking-widest uppercase text-base-content/50"
