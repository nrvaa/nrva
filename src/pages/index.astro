---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

import imgMhisq from "../assets/images/mhisq.jpg";
import imgMhisqWebp from "../assets/images/mhisq.webp";
import imgUILY from "../assets/images/UILY.jpg";
import imgSanctuary from "../assets/images/Sanctuary.jpg";
import imgLikethis from "../assets/images/likethis.jpg";
import imgMonochrome from "../assets/images/Monochrome.jpg";
import imgIlluminate from "../assets/images/illuminate.jpg";
import imgDwul from "../assets/images/DWUL SQ.webp";
import imgNiki from "../assets/images/NIKI Square.png";
import imgPfp from "../assets/images/PFP Enhanced Halftone Lighting.webp";
import imgTst from "../assets/images/TST SQ.png";
import imgHalfway from "../assets/images/halfway there main.png";
import imgUntitled from "../assets/images/Untitled-1.png";
import imgVert from "../assets/images/VERT_wewewe.webp";
import imgDieweomom from "../assets/images/dieweomom.webp";
