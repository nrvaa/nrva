---
export interface Props {
  isCompact?: boolean;
}
const { isCompact = false } = Astro.props;
---

{isCompact ? (
  <footer class="fixed bottom-0 left-0 w-full py-6 text-center z-50 pointer-events-none">
    <div class="flex items-center justify-center gap-4 text-[10px] font-mono text-base-content/30 uppercase tracking-[0.2em]">
      <span>&copy; 2026 NRVA</span>
      <span class="opacity-50">|</span>
      <span>VDT-Y4</span>
    </div>
  </footer>
) : (
  <footer class="mt-24 pb-0">
    <!-- pb-32 ensures dock doesn't cover footer content -->
    <div class="bg-white/10 backdrop-blur-lg border border-white/20 shadow-lg border-t border-base-content/10 py-12 rounded-none">
    <div
      class="max-w-4xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8 text-sm text-base-content/60 font-mono text-center md:text-left"
    >
      <p>&copy; 2026 NRVA. All rights reserved.</p>

      <div
        class="badge badge-primary badge-outline py-4 px-6 rounded-full shadow-[0_0_15px_rgba(var(--color-primary),0.3)]"
      >
        Made with <i class="fa-solid fa-heart"></i> by VDT-Y4 | <img src="/favicon.svg" alt="" class="size-5">
      </div>

      <!-- <div class="flex flex-wrap justify-center gap-6 font-bold">
        <a
          href="#"
          class="hover:text-primary transition-colors flex items-center gap-2"
        >
          <span class="icon-[tabler--brand-spotify] size-5"></span> Spotify
        </a>
        <a
          href="#"
          class="hover:text-primary transition-colors flex items-center gap-2"
        >
          <span class="icon-[tabler--brand-soundcloud] size-5"></span> Soundcloud
        </a>
        <a
          href="#"
          class="hover:text-primary transition-colors flex items-center gap-2"
        >
          <span class="icon-[tabler--brand-instagram] size-5"></span> Instagram
        </a> -->
      <!-- </div> -->
    </div>
    </div>
  </footer>
)}
