---
export interface Props {
  isCorePage?: boolean;
}
const { isCorePage = false } = Astro.props;
---

<nav
  class="nav-pill bg-white/10 backdrop-blur-lg border border-white/20 shadow-lg"
  aria-label="Primary"
>
  <a href="/" class="nav-wordmark">
    <img
      src="/Both white.svg"
      alt="NRVA"
      class="h-6 w-auto opacity-90 hover:opacity-100 transition-opacity nav-logo"
    />
  </a>
  <input type="checkbox" id="nav-toggle" class="nav-toggle-checkbox" hidden />
  <div class="nav-links">
    {
      isCorePage ? (
        <a href="/">Home</a>
      ) : (
        <>
          <a href="/#latest">Latest</a>
          <a href="/#about">About</a>
          <a href="/#discography">Discography</a>
          <a href="/core">Core</a>
        </>
      )
    }
  </div>
  <div class="nav-actions">
    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle Theme">
      <i class="fas fa-moon dark-icon"></i>
      <i class="fas fa-sun light-icon" style="display: none;"></i>
    </button>
    <a href="/#latest" class="nav-cta">Listen</a>
    <label for="nav-toggle" class="nav-toggle-label">Menu</label>
  </div>
</nav>

<script>
  document.addEventListener("astro:page-load", () => {
    // Theme Toggle Logic
    const themeToggle = document.getElementById("theme-toggle");
    const darkIcon = document.querySelector(".dark-icon");
    const lightIcon = document.querySelector(".light-icon");

    function updateIcons(theme) {
      if (theme === "light") {
        darkIcon.style.display = "none";
        lightIcon.style.display = "block";
      } else {
        darkIcon.style.display = "block";
        lightIcon.style.display = "none";
      }
    }

    // Check saved theme or system preference
    let currentTheme = localStorage.getItem("theme");
    if (!currentTheme) {
      currentTheme = window.matchMedia("(prefers-color-scheme: light)").matches
        ? "light"
        : "dark";
    }

    if (currentTheme === "light") {
      document.documentElement.setAttribute("data-theme", "light");
    }
    updateIcons(currentTheme);

    // Toggle theme
    themeToggle?.addEventListener("click", () => {
      const isLight =
        document.documentElement.getAttribute("data-theme") === "light";
      const newTheme = isLight ? "dark" : "light";

      if (newTheme === "light") {
        document.documentElement.setAttribute("data-theme", "light");
      } else {
        document.documentElement.removeAttribute("data-theme");
      }

      localStorage.setItem("theme", newTheme);
      updateIcons(newTheme);
    });
  });
</script>

<style>
  .nav-pill {
    position: fixed;
    top: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    width: min(90%, 640px);
    height: 56px;
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--space-xs) 0 var(--space-lg);
    z-index: 100;
    box-shadow: var(--neumorph-out);
  }
  .nav-wordmark {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--text-md);
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .nav-links {
    display: flex;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 500;
  }
  .nav-links a {
    color: var(--color-ink-2);
    padding: var(--space-3xs) var(--space-2xs);
  }
  .nav-links a:hover {
    color: var(--color-accent);
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }
  .nav-cta {
    background: var(--color-paper);
    color: var(--color-accent);
    padding: var(--space-2xs) var(--space-sm);
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    font-weight: 600;
    box-shadow: var(--neumorph-out-sm);
    transition: all var(--dur-short, 0.2s) var(--ease-out, ease);
  }
  .nav-cta:hover {
    transform: translateY(1px);
    box-shadow: var(--neumorph-in-sm);
    color: var(--color-accent);
  }
  .theme-toggle {
    background: var(--color-paper);
    border: none;
    color: var(--color-ink);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--neumorph-out-sm);
    transition: all 0.3s ease;
  }
  .theme-toggle:hover {
    box-shadow: var(--neumorph-in-sm);
    color: var(--color-accent);
  }
  .nav-toggle-label {
    display: none;
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    padding: var(--space-2xs);
  }
  @media (max-width: 640px) {
    .nav-links {
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition:
        opacity var(--dur-medium, 0.3s) var(--ease-out, ease),
        transform var(--dur-medium, 0.3s) var(--ease-out, ease),
        visibility var(--dur-medium, 0.3s) var(--ease-out, ease);
      position: absolute;
      top: calc(100% + var(--space-xs));
      left: 0;
      width: 100%;
      background: var(--color-paper);
      border-radius: var(--radius-lg);
      padding: var(--space-md);
      flex-direction: column;
      gap: var(--space-md);
      box-shadow: var(--neumorph-out);
    }
    .nav-toggle-checkbox:checked ~ .nav-links {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    .nav-toggle-label {
      display: block;
    }
  }
</style>
