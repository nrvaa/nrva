---
import { ClientRouter } from "astro:transitions";
const { title = "NRVA", description = "NRVA Electronic Music" } = Astro.props;
---

<!doctype html>
<html lang="en" class="overflow-x-clip">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/Sun Only white.svg" />
    <link rel="icon" href="/Sun Only white.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <ClientRouter />
  </head>
  <body
    class="font-sans antialiased overflow-x-clip min-h-screen relative selection:bg-primary/20 text-base-content"
  >
    <!-- Simple Gradient Background -->
    <div class="fixed inset-0 z-[-2] simple-gradient-bg"></div>
    <div
      class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none"
      aria-hidden="true"
    >
      <!-- Subtle grid overlay -->
      <div
        class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.001)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.001)_1px,transparent_1px)] bg-[size:60px_60px]"
      >
      </div>

      <!-- Geometric Parallax Shapes -->
      <div class="parallax-layer parallax-layer-1">
        <svg
          viewBox="0 0 200 200"
          class="parallax-shape"
          xmlns="http://www.w3.org/2000/svg"
        >
          <circle
            cx="100"
            cy="100"
            r="90"
            stroke="currentColor"
            stroke-width="0.5"
            stroke-dasharray="2 4"
            fill="none"></circle>
          <circle
            cx="100"
            cy="100"
            r="70"
            stroke="currentColor"
            stroke-width="0.7"
            fill="none"></circle>
          <circle
            cx="100"
            cy="100"
            r="50"
            stroke="currentColor"
            stroke-width="0.7"
            stroke-dasharray="10 5"
            fill="none"></circle>
          <line
            x1="10"
            y1="100"
            x2="190"
            y2="100"
            stroke="currentColor"
            stroke-width="0.6"></line>
          <line
            x1="100"
            y1="10"
            x2="100"
            y2="190"
            stroke="currentColor"
            stroke-width="0.6"></line>
          <line
            x1="36"
            y1="36"
            x2="164"
            y2="164"
            stroke="currentColor"
            stroke-width="0.6"></line>
          <line
            x1="36"
            y1="164"
            x2="164"
            y2="36"
            stroke="currentColor"
            stroke-width="0.6"></line>
        </svg>
      </div>
      <div class="parallax-layer parallax-layer-2">
        <svg
          viewBox="0 0 200 200"
          class="parallax-shape shape-reverse"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Digital crosshair/grid aesthetic -->
          <rect
            x="20"
            y="20"
            width="160"
            height="160"
            stroke="currentColor"
            stroke-width="0.6"
            fill="none"></rect>
          <rect
            x="40"
            y="40"
            width="120"
            height="120"
            stroke="currentColor"
            stroke-width="0.6"
            stroke-dasharray="5 5"
            fill="none"></rect>
          <circle
            cx="100"
            cy="100"
            r="30"
            stroke="currentColor"
            stroke-width="0.6"
            fill="none"></circle>
          <path
            d="M 0,100 L 200,100 M 100,0 L 100,200"
            stroke="currentColor"
            stroke-width="0.3"
            stroke-dasharray="2 2"></path>
          <path
            d="M 100,80 L 100,120 M 80,100 L 120,100"
            stroke="currentColor"
            stroke-width="1"></path>
        </svg>
      </div>

      <!-- Grain texture -->
      <svg
        class="absolute inset-0 w-full h-full opacity-[0.03] mix-blend-overlay"
      >
        <filter id="grain"
          ><feTurbulence
            type="fractalNoise"
            baseFrequency="0.8"
            numOctaves="4"
            stitchTiles="stitch"></feTurbulence></filter
        >
        <rect width="100%" height="100%" filter="url(#grain)"></rect>
      </svg>

      <!-- Background atmosphere (Blooms) -->
      <div class="atmospheric-bloom bloom-top-right"></div>
      <div class="atmospheric-bloom bloom-bottom-left"></div>
    </div>

    <slot />
  </body>
</html>

<style>
  /* Lenis smooth scroll */
  html.lenis,
  html.lenis body {
    height: auto;
  }
  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }
  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }
  .lenis.lenis-stopped {
    overflow: clip;
  }
  .lenis.lenis-scrolling iframe {
    pointer-events: none;
  }

  html,
  body {
    margin: 0;
    width: 100%;
    overflow-x: clip;
  }

  /* Simple Gradient Background */
  .simple-gradient-bg {
    background: linear-gradient(
      145deg,
      var(--color-paper-2) 0%,
      var(--color-paper) 100%
    );
    transition: background 0.5s ease;
  }

  /* Geometric Parallax Shapes */
  .parallax-layer {
    position: absolute;
    will-change: transform;
    opacity: 0.8;
  }
  .parallax-layer-1 {
    top: 15%;
    right: -10%;
    width: 70vw;
    height: 70vw;
    max-width: 800px;
    max-height: 800px;
  }
  .parallax-layer-2 {
    top: 60%;
    left: -15%;
    width: 90vw;
    height: 90vw;
    max-width: 1000px;
    max-height: 1000px;
  }
  .parallax-shape {
    width: 100%;
    height: 100%;
    color: rgba(255, 255, 255, 0.04);
    animation: rotateSlow 80s linear infinite;
  }
  .parallax-shape.shape-reverse {
    animation: rotateSlowReverse 100s linear infinite;
  }
  /* Atmospheric blooms */
  .atmospheric-bloom {
    position: fixed;
    width: 60vw;
    height: 60vw;
    border-radius: 50%;
    background: radial-gradient(
      circle at center,
      var(--color-accent) 0%,
      transparent 70%
    );
    opacity: 0.08;
    pointer-events: none;
    z-index: -1;
    filter: blur(80px);
    animation: floatBloom 20s infinite alternate ease-in-out;
  }

  .bloom-top-right {
    top: -20vw;
    right: -10vw;
    animation-delay: -5s;
  }

  .bloom-bottom-left {
    bottom: -20vw;
    left: -20vw;
    animation-duration: 25s;
  }

  @keyframes floatBloom {
    0% {
      transform: translate(0, 0) scale(1);
    }
    100% {
      transform: translate(5vw, 10vw) scale(1.15);
    }
  }

  @keyframes rotateSlow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  @keyframes rotateSlowReverse {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(-360deg);
    }
  }

  /* Invert color in light mode */
  :root[data-theme="light"] .parallax-shape {
    color: rgba(0, 0, 0, 0.06);
  }
</style>
